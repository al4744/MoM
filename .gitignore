# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
/dist/
/build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Profiling artifacts (large files)
profiling/*.json
profiling/*.trace
profiling/*.nsys-rep
profiling/*.qdrep

# Model weights (download separately, root-level only)
/models/
*.bin
*.safetensors
*.pt
*.pth

# Traces (generated, can be large)
/traces/

# Eval results (generated by evaluation/run_eval.py)
/results_dry/
/results_quant/

# pytest
.pytest_cache/

# WandB
wandb/

# Jupyter
.ipynb_checkpoints/

# Misc
*.log
*.tmp

# vLLM build artifacts (generated during pip install -e)
vllm/build/
vllm/dist/
vllm/*.egg-info/
*.so
*.o
*.a
